{
  "name": "Angličtina",
  "short_name": "ANG",
  "start_url": ".",
  "display": "standalone",
  "background_color": "#111827",
  "theme_color": "#111827",
  "icons": [
    { "src": "/android-chrome-192x192.webp", "sizes": "192x192", "type": "image/webp" },
    { "src": "/android-chrome-512x512.webp", "sizes": "512x512", "type": "image/webp" }
  ],
  "id": "/",
  "display_override": ["window-controls-overlay", "standalone"],
  "protocol_handlers": [
    {
      "protocol": "web+ang",
      "url": "/?url=%s"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/desktop.webp",
      "sizes": "1200x800",
      "type": "image/webp",
      "form_factor": "wide"
    },
    {
      "src": "/screenshots/mobile.webp",
      "sizes": "280x525",
      "type": "image/webp"
    }
  ]
}
